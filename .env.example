PORT=8787
# When empty, admin endpoints are reachable from loopback (127.0.0.1/::1) only.
# Set a token to allow admin access from non-loopback IPs.
ADMIN_TOKEN=
DATA_FILE=./data/state.json
# Aggregated stats and per-key 60-min timeseries (defaults to <DATA_FILE dir>/stats.json)
STATS_FILE=./data/stats.json
METRICS_PATH=/metrics
UPSTREAM_TIMEOUT_MS=30000
# Request body bytes to buffer in memory before switching to stream-through.
# Bodies <= this size keep cross-key retry; larger bodies stream and only get one upstream attempt.
BODY_BUFFER_LIMIT_BYTES=1048576
